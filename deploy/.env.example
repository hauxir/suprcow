# Wildcard base domain for previews (DNS *.<this> must point at this host).
BASE_DOMAIN=preview.example.com

# Cloudflare API token with DNS edit rights, for Caddy's ACME DNS-01 challenge.
CF_API_TOKEN=cf-token-here

# Git clone URL for the project suprcow serves.
REPO_URL=https://github.com/me/myapp.git

# GitHub App credentials. suprcow is a single GitHub App that handles webhooks,
# user login, and private-repo cloning. Create one at
# Settings -> Developer settings -> GitHub Apps, install it on your repo, then:
#   - callback:  https://suprcow.<BASE_DOMAIN>/_suprcow/auth/callback
#   - webhook:   https://suprcow.<BASE_DOMAIN>/_suprcow/hooks/github
#   - permissions: Contents:Read, Metadata:Read, Pull requests:Read; event: Pull request
# To turn the access gate off instead, set `auth: { disabled: true }` in preview.yml.
SUPRCOW_WEBHOOK_SECRET=the-apps-webhook-secret
SUPRCOW_GITHUB_CLIENT_ID=the-apps-client-id
SUPRCOW_GITHUB_CLIENT_SECRET=the-apps-client-secret
SUPRCOW_GITHUB_APP_ID=123456
SUPRCOW_GITHUB_APP_PRIVATE_KEY_FILE=/run/secrets/suprcow-app.pem
SUPRCOW_SESSION_KEY=run-openssl-rand-hex-32-and-paste-here
